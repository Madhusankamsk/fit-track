# Docker / Portainer environment variables
# - Portainer: paste these into Stack → Environment variables (no .env file required)
# - Local CLI: optional — copy to .env or use defaults from docker-compose.yml
# Containers use internal hostnames (postgres, redis), not localhost.

# CPU architecture (linux/amd64 for typical Ubuntu VPS; use linux/arm64 on ARM hosts)
DOCKER_PLATFORM=linux/amd64
# Image tag — use amd64-v2 on x86_64, arm64-v2 on aarch64 (change when switching arch)
IMAGE_TAG=amd64-v2

# Host ports (avoid clashes with existing postgres/redis/nginx on the server)
POSTGRES_HOST_PORT=5433
REDIS_HOST_PORT=6380
NGINX_HTTP_PORT=8080
NGINX_HTTPS_PORT=8443

DB_PASSWORD=strongpassword
DATABASE_URL=postgresql://fittrack:strongpassword@postgres:5432/fittrack_db?schema=public
REDIS_URL=redis://redis:6379

JWT_SECRET=replace_with_256bit_random_secret_never_expose
JWT_REFRESH_SECRET=replace_with_different_256bit_secret
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

AUTH_SERVICE_PORT=5001
INGESTION_API_PORT=5002
ANALYTICS_SERVICE_PORT=5003

NODE_ENV=production
BCRYPT_ROUNDS=12
MAX_WAYPOINTS_PER_ACTIVITY=100000
ACTIVITY_QUEUE_NAME=activity_queue

# Auto-seed default login on auth service startup (defaults to true in compose)
SEED_ON_STARTUP=true
SEED_USERNAME=runner1
SEED_EMAIL=runner1@test.com
SEED_PASSWORD=Securepass1!
